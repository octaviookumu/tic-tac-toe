{
  "name": "tac-toe",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/tac-toe/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/tac-toe",
        "browser": "apps/tac-toe/src/main.ts",
        "tsConfig": "apps/tac-toe/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/tac-toe/public"
          }
        ],
        "styles": ["apps/tac-toe/src/styles.css"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "serviceWorker": "apps/tac-toe/ngsw-config.json"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "defaultConfiguration": "development",
      "configurations": {
        "production": {
          "buildTarget": "tac-toe:build:production"
        },
        "development": {
          "buildTarget": "tac-toe:build:development"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "tac-toe:build",
        "port": 4200,
        "staticFilePath": "dist/apps/tac-toe/browser",
        "spa": true
      }
    }
  }
}
